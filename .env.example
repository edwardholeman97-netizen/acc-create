# Public URL of this app (no trailing slash) — for admin password reset emails. Optional if same as browser host.
# Production example: https://sampath.companysite.site
APP_BASE_URL=http://localhost:8000

# hCaptcha for admin login (https://www.hcaptcha.com/). Leave empty on local dev to skip the challenge.
# In hCaptcha dashboard, add hostname: sampath.companysite.site (and localhost for testing if needed).
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# CSE API
CSE_API_BASE_URL=https://uat-cseapi.cse.lk
CSE_API_USERNAME=
CSE_API_PASSWORD=
ALLOWED_BROKER_FILTER=S C SECURITIES

# Database
DB_HOST=localhost
DB_NAME=cds_accounts
DB_USER=
DB_PASSWORD=

# SMTP (for account creation and admin update emails)
SMTP_HOST=premium248-5.web-hosting.com
SMTP_USERNAME=sampath.securities@companysite.site
SMTP_PASSWORD=
SMTP_PORT=465
SMTP_ENCRYPTION=ssl

# Optional: comma-separated emails notified when an admin successfully updates a CDS submission
ADMIN_NOTIFY_EMAIL=ops@example.com,admin@example.com

# Environment: production | staging | local
APP_ENV=local
APP_DEBUG=1

# CORS: in production set to your frontend origin, e.g. https://cds.yourdomain.com
CORS_ALLOW_ORIGIN=*



